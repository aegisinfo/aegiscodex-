# aegiscode — API Keys
# Add at least one model key to get started

# Required: at least one of these
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Optional: cloud sync (aegiscloud.org → Account Settings)
AEGISCLOUD_API_KEY=aegis_...

# Optional: semantic memory ($2/month at aegiscloud.org → /memory)
AEGIS_MEMORY_TOKEN=

{
  "name": "aegiscode-gui",
  "version": "1.0.0",
  "description": "AEGIS Code — Desktop GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "node build-prod.mjs --linux",
    "build:win":   "node build-prod.mjs --win",
    "build:mac":   "node build-prod.mjs --mac",
    "build:all":   "node build-prod.mjs --linux --win --mac"
  },
  "build": {
    "appId": "org.aegiscloud.aegiscode",
    "productName": "AEGIS Code",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "files": [
      "**/*",
      "!node_modules/electron-builder/**",
      "!build-prod.mjs"
    ],
    "linux": {
      "target": "deb",
      "category": "Development",
      "icon": "icons/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "javascript-obfuscator": "^5.4.3"
  }
}

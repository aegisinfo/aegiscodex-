{
  "name": "aegiscode-gui",
  "version": "1.0.0",
  "description": "AEGIS Code — Desktop GUI",
  "author": {
    "name": "Niklas Borneklint",
    "email": "nborneklint@gmail.com"
  },
  "homepage": "https://aegiscloud.org/aegiscode",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "node build-prod.mjs --linux",
    "build:win": "node build-prod.mjs --win",
    "build:mac": "node build-prod.mjs --mac",
    "build:all": "node build-prod.mjs --linux --win --mac"
  },
  "build": {
    "appId": "org.aegiscloud.aegiscode",
    "productName": "AEGIS Code",
    "asar": true,
    "npmRebuild": false,

    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**"
    ],
    "extraResources": [
      { "from": "../dist/main.js", "to": "dist/main.js" },
      { "from": "icons",           "to": "icons"         }
    ],
    "files": [
      "**/*",
      "!node_modules/electron-builder/**",
      "!build-prod.mjs"
    ],
    "linux": {
      "target": "deb",
      "category": "Development",
      "icon": "icons/icon.png",
      "desktop": {
        "Name": "AEGIS Code",
        "Comment": "AI coding assistant",
        "Categories": "Development;IDE;",
        "StartupWMClass": "aegis-code"
      }
    },
    "win": {
      "target": "msi",
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "javascript-obfuscator": "^5.4.3"
  },
  "overrides": {
    "node-gyp": "^10.0.0"
  }
}
